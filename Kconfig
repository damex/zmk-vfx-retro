menuconfig VFX_RETRO
    bool "Retro pixel-art status screen"
    depends on ZMK_DISPLAY
    select LV_USE_CANVAS
    help
      Pixel-art status screen for ZMK displays.

if VFX_RETRO

config VFX_RETRO_PANEL_WIDTH
    int "Panel width (px)"
    default 160

config VFX_RETRO_PANEL_HEIGHT
    int "Panel height (px)"
    default 68

config VFX_RETRO_REFRESH_MS
    int "Refresh interval (ms)"
    default 1000
    help
      Status screen redraw period.

endif # VFX_RETRO
